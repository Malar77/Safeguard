{
  "appId": "in.safeguard.app",
  "appName": "SafeGuard",
  "webDir": "build",
  "bundledWebRuntime": false,
  "server": {
    "cleartext": true,
    "allowNavigation": ["*"]
  },
  "android": {
    "allowMixedContent": true,
    "backgroundColor": "#FFFFFF"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#7c3aed",
      "showSpinner": false
    }
  }
}
